# Neon Postgres connection string (Project → Connection Details).
# When set, votes are persisted and shared live across all visitors.
# Leave blank to run in local demo mode (seeded counts, no persistence).
DATABASE_URL=

# Optional. Required to reset live votes in production via DELETE /api/votes.
VOTE_RESET_TOKEN=

# Optional. Primary live score API key for SportsData.io:
# https://api.sportsdata.io/v4/soccer/scores/json/GamesByDate/YYYY-MM-DD
SPORTSDATA_API_KEY=

# Optional. Fallback TheSportsDB API key for live soccer scores. Defaults to the
# free public test key "3" if not set — no signup required.
THESPORTSDB_KEY=

# Optional. Google AdSense. Set to serve real ads; otherwise tidy ad
# placeholders are shown.
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_SLOT_BANNER=
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=

# SEO. Canonical origin used in robots.txt, sitemap.xml, and JSON-LD.
# Defaults to https://who-is-the-goat.vercel.app if not set.
NEXT_PUBLIC_SITE_URL=

# Optional. Google Search Console verification meta tag value.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
