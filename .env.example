# Neon Postgres connection string (Project → Connection Details).
# When set, votes are persisted and shared live across all visitors.
# Leave blank to run in local demo mode (seeded counts, no persistence).
DATABASE_URL=

# Optional. Required to reset live votes in production via DELETE /api/votes.
VOTE_RESET_TOKEN=

# Optional. Live score API token for Football-Data.org:
# https://api.football-data.org/v4/matches
FOOTBALL_DATA_API_KEY=

# Optional. Google AdSense. Set to serve real ads; otherwise tidy ad
# placeholders are shown.
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_SLOT_BANNER=
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=

# Optional. Adsterra. Set to serve real ads; overrides AdSense for configured slots.
# Key (e.g. 2b591b65eb63ad315ad709c9dbfa188a) for the sidebar ad unit (usually 300x250)
NEXT_PUBLIC_ADSTERRA_SIDEBAR_KEY=
NEXT_PUBLIC_ADSTERRA_SIDEBAR_WIDTH=300
NEXT_PUBLIC_ADSTERRA_SIDEBAR_HEIGHT=250

# Keys for the bottom banner (e.g. 728x90 desktop, 320x50 mobile)
NEXT_PUBLIC_ADSTERRA_BANNER_KEY=
NEXT_PUBLIC_ADSTERRA_BANNER_MOBILE_KEY=
NEXT_PUBLIC_ADSTERRA_BANNER_WIDTH=728
NEXT_PUBLIC_ADSTERRA_BANNER_HEIGHT=90

# Optional. Adsterra domain (defaults to www.highperformanceformat.com)
NEXT_PUBLIC_ADSTERRA_DOMAIN=
# Optional. Adsterra script format (iframe or js) - defaults to iframe
NEXT_PUBLIC_ADSTERRA_FORMAT=iframe

# Optional. Adsterra script URLs for Popunder and Social Bar ads (e.g. //pl123456.highratecpm.com/xx/xx/xx/xxxxxx.js)
NEXT_PUBLIC_ADSTERRA_POPUNDER_URL=
NEXT_PUBLIC_ADSTERRA_SOCIAL_BAR_URL=

# SEO. Canonical origin used in robots.txt, sitemap.xml, and JSON-LD.
# Defaults to https://who-is-the-goat.vercel.app if not set.
NEXT_PUBLIC_SITE_URL=

# Optional. Google Search Console verification meta tag value.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
